#include <stdio.h>
#include <conio.h>      // для _getch()
#include <string.h>
#include <windows.h>    // для SetConsoleCP

#define MAX 30

struct student
{
    char fam[50];
    char name[50];
    char otch[50];
    char address[100];
    char group[20];
    float rating;
};

struct student students[MAX];
int count = 0;

// прототипы функций
void input();
void sort();
void search();
void modify();
void delete_student();
void output();

int main()
{
    // поддержка русского языка в консоли
    SetConsoleCP(1251);
    SetConsoleOutputCP(1251);

    int choice;
    do
    {
        printf("\n===== МЕНЮ =====\n");
        printf("1. Ввод массива структур\n");
        printf("2. Сортировка по фамилии\n");
        printf("3. Поиск по фамилии\n");
        printf("4. Изменение структуры\n");
        printf("5. Удаление структуры\n");
        printf("6. Вывод массива\n");
        printf("7. Выход\n");
        printf("Ваш выбор: ");
        scanf_s("%d", &choice);
        while (getchar() != '\n'); // очистка буфера после scanf

        switch (choice)
        {
        case 1: input(); break;
        case 2: sort(); break;
        case 3: search(); break;
        case 4: modify(); break;
        case 5: delete_student(); break;
        case 6: output(); break;
        case 7: printf("Выход из программы.\n"); break;
        default: printf("Неверный пункт меню!\n");
        }
    } while (choice != 7);

    printf("Нажмите любую клавишу для выхода...\n");
    _getch();
    return 0;
}

// 1 ввод массива 
void input()
{
    printf("Введите количество студентов (макс. %d): ", MAX);
    int n;
    scanf_s("%d", &n);
    while (getchar() != '\n'); // очистка

    if (n < 1 || n > MAX)
    {
        printf("Некорректное количество! Допустимо от 1 до %d.\n", MAX);
        return;
    }

    count = 0;
    for (int i = 0; i < n; i++)
    {
        printf("\nСтудент №%d:\n", i + 1);
        printf("Фамилия: ");
        scanf_s("%49s", students[i].fam, (unsigned)_countof(students[i].fam));
        while (getchar() != '\n'); // очистка (на случай, если введено больше 49 символов)

        printf("Имя: ");
        scanf_s("%49s", students[i].name, (unsigned)_countof(students[i].name));
        while (getchar() != '\n');

        printf("Отчество: ");
        scanf_s("%49s", students[i].otch, (unsigned)_countof(students[i].otch));
        while (getchar() != '\n');

        printf("Адрес: ");
        scanf_s("%99s", students[i].address, (unsigned)_countof(students[i].address));
        while (getchar() != '\n');

        printf("Группа: ");
        scanf_s("%19s", students[i].group, (unsigned)_countof(students[i].group));
        while (getchar() != '\n');

        printf("Рейтинг: ");
        scanf_s("%f", &students[i].rating);
        while (getchar() != '\n');

        count++;
    }
    printf("Введено студентов: %d\n", count);
}

// 2 сортировка по фамилии (алф порядок)
void sort()
{
    if (count == 0)
    {
        printf("Массив пуст! Нечего сортировать.\n");
        return;
    }

    struct student temp;
    for (int i = 0; i < count - 1; i++)
    {
        for (int j = i + 1; j < count; j++)   
        {
            if (strcmp(students[i].fam, students[j].fam) > 0)
            {
                temp = students[i];
                students[i] = students[j];
                students[j] = temp;
            }
        }
    }
    printf("Массив отсортирован по фамилии.\n");
}

// 3 поиск по фамилии
void search()
{
    if (count == 0)
    {
        printf("Массив пуст!\n");
        return;
    }

    char target[50];
    printf("Введите фамилию для поиска: ");
    gets_s(target, sizeof(target));   // указан размер

    int found = 0;
    for (int i = 0; i < count; i++)
    {
        if (strcmp(students[i].fam, target) == 0)
        {
            printf("\nНайден студент #%d:\n", i + 1);
            printf("Фамилия: %s\n", students[i].fam);
            printf("Имя: %s\n", students[i].name);
            printf("Отчество: %s\n", students[i].otch);
            printf("Адрес: %s\n", students[i].address);
            printf("Группа: %s\n", students[i].group);
            printf("Рейтинг: %.2f\n", students[i].rating);
            found = 1;
        }
    }
    if (!found)
        printf("Студент с фамилией '%s' не найден.\n", target);
}

// 4 изменение структуры
void modify()
{
    if (count == 0)
    {
        printf("Массив пуст!\n");
        return;
    }

    char target[50];
    printf("Введите фамилию студента для изменения: ");
    gets_s(target, sizeof(target));

    for (int i = 0; i < count; i++)
    {
        if (strcmp(students[i].fam, target) == 0)
        {
            printf("Найден студент. Введите новые данные:\n");
            printf("Фамилия: ");
            gets_s(students[i].fam, sizeof(students[i].fam));
            printf("Имя: ");
            gets_s(students[i].name, sizeof(students[i].name));
            printf("Отчество: ");
            gets_s(students[i].otch, sizeof(students[i].otch));
            printf("Адрес: ");
            gets_s(students[i].address, sizeof(students[i].address));
            printf("Группа: ");
            gets_s(students[i].group, sizeof(students[i].group));
            printf("Рейтинг: ");
            scanf_s("%f", &students[i].rating);
            while (getchar() != '\n'); // очистка после scanf
            printf("Данные обновлены.\n");
            return;
        }
    }
    printf("Студент с фамилией '%s' не найден.\n", target);
}

// 5 удаление структуры
void delete_student()   // имя совпадает с прототипом
{
    if (count == 0)
    {
        printf("Массив пуст!\n");
        return;
    }

    char target[50];
    printf("Введите фамилию студента для удаления: ");
    gets_s(target, sizeof(target));

    for (int i = 0; i < count; i++)
    {
        if (strcmp(students[i].fam, target) == 0)
        {
            // сдвиг элементов влево
            for (int j = i; j < count - 1; j++)
            {
                students[j] = students[j + 1];
            }
            count--;
            printf("Студент с фамилией '%s' удалён.\n", target);
            return;
        }
    }
    printf("Студент с фамилией '%s' не найден.\n", target);
}

// 6 вывод массива
void output()
{
    if (count == 0)
    {
        printf("Массив пуст!\n");
        return;
    }

    printf("\nСписок студентов:\n");
    for (int i = 0; i < count; i++)
    {
        printf("\n--- Студент #%d ---\n", i + 1);
        printf("Фамилия: %s\n", students[i].fam);
        printf("Имя: %s\n", students[i].name);
        printf("Отчество: %s\n", students[i].otch);
        printf("Адрес: %s\n", students[i].address);
        printf("Группа: %s\n", students[i].group);
        printf("Рейтинг: %.2f\n", students[i].rating);
    }
}
