#include <stdio.h>
#define max 10

int main()
{
    FILE* input, * output;
     int a[max];
    for (int i = 0; i < max; i++)
    {
        scanf("%d", &a[i]);
    }
    input = fopen("input.txt", "w");
    for (int i = 0; i < max; i++)
    {
        fprintf(input, "%d ", a[i]);
    }
    fclose(input);
    input = fopen("input.txt", "r");
    for (int i = 0; i < max; i++)
    {
        fscanf(input, "%d ", &a[i]);
    }
    fclose(input);
    output = fopen("output.txt", "w");
     for (int i = 1; i < max; i+=2)
     {
         fprintf(output, "%d ", a[i]);
     }
        fclose(output);
    return 0;
}
