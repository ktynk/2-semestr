#include <stdio.h>
#include <conio.h>
#include <string.h>
#include <stdlib.h>

struct chitatel
{
    char fam[50];
    char name[50];
    char otch[50];
    char book_name[50];
    char srok_sdachi[20];
};

struct chitatel* chitatels = NULL;
int chitatel_count = 0;
int chitatel_emkost = 0;

void input();
void sort();
void search();
void delete_chitatel();
void output();
void save_to_file();

int main()
{
    int choice;

    do
    {
        printf("\n===== МЕНЮ =====\n");
        printf("1. Ввод читателя\n");
        printf("2. сортировка по фамилии\n");
        printf("3. поиск по фамилии\n");
        printf("4. удалить читателя\n");
        printf("5. показать всех читателей сейчсас\n");
        printf("6. Вывод всех читателей\n");
        printf("Ваш выбор: ");
        scanf("%d", &choice);
        getchar();

        switch (choice)
        {
        case 1: input();break;
        case 2: sort(); break;
        case 3: search(); break;
        case 4: delete_chitatel(); break;
        case 5: output();break;
        case 6: save_to_file();break;
        case 7: printf("Выход из программы.\n"); break;
        default: printf("Неверный пункт меню!\n");
        }

    } while (choice != 7);
       printf("Нажмите esc для выхода\n");
    int ch;
    do {
        ch = getchar();
    } while (ch != 27);
    free(chitatels);
    return 0;
}

void input()
{
    if (chitatel_count == chitatel_emkost)
    {
        int new_emkost = (chitatel_emkost == 0) ? 1 : chitatel_emkost * 2;
        struct chitatel* temp = realloc(chitatels, new_emkost * sizeof(struct chitatel));

        if (temp == NULL)
        {
            printf("Ошибка выделения памяти!\n");
            return;
        }

        chitatels = temp;
        chitatel_emkost = new_emkost;
    }

    printf("\nЧитатель %d:\n", chitatel_count + 1);
    printf("Введите фамилию: ");
    gets(chitatels[chitatel_count].fam);
    printf("Введите имя: ");
    gets( chitatels[chitatel_count].name);
    printf("Введите отчество: ");
    gets( chitatels[chitatel_count].otch);
    printf("Введите название книги:");
    gets(chitatels[chitatel_count].book_name);
    printf("Введите срок сдачи: ");
    scanf("%s", chitatels[chitatel_count].srok_sdachi);
    getchar();
    chitatel_count++;
    printf("Читатель успешно добавлен!\n");
}

void output()
{
    if (chitatel_count == 0)
    {
        printf("Список читателей пуст!\n");
        return;
    }

    printf("\n===== СПИСОК ЧИТАТЕЛЕЙ =====\n");

    for (int i = 0; i < chitatel_count; i++)
    {
        printf("\nЧитатель №%d\n", i + 1);
        printf("Фамилия: %s\n", chitatels[i].fam);
        printf("Имя: %s\n", chitatels[i].name);
        printf("Отчество: %s\n", chitatels[i].otch);
        printf("Книга: %s\n", chitatels[i].book_name);
        printf("Срок сдачи: %s\n", chitatels[i].srok_sdachi);
    }
}
void sort()
{
    if (chitatel_count == 0)
    {
        printf("Массив пуст! Нечего сортировать.\n");
        return;
    }
    struct chitatel temp1;
    for (int i = 0; i < chitatel_count - 1; i++)
    {
        for (int j = i + 1; j < chitatel_count; j++)   
        {
            if (strcmp(chitatels[i].fam, chitatels[j].fam) > 0)
            {
                temp1 = chitatels[i];
                chitatels[i] = chitatels[j];
                chitatels[j] = temp1;
            }
        }
    }
    printf("Массив отсортирован по фамилии.\n");
}
void search()
{
    if (chitatel_count == 0)
    {
        printf("Массив пуст!\n");
        return;
    }

    char target[50];
    printf("Введите фамилию для поиска: ");
    gets(target);   // без while(getchar...) и без getchar() после

    int found = 0;
    for (int i = 0; i < chitatel_count; i++)
    {
        if (strcmp(chitatels[i].fam, target) == 0)
        {
            printf("\nНайден читатель #%d:\n", i + 1);
            printf("Фамилия: %s\n", chitatels[i].fam);
            printf("Имя: %s\n", chitatels[i].name);
            printf("Отчество: %s\n", chitatels[i].otch);
            printf("Книга: %s\n", chitatels[i].book_name);
            printf("срок сдачи: %s\n", chitatels[i].srok_sdachi);
            found = 1;
        }
    }

    if (!found)
        printf("читатель с фамилией '%s' не найден.\n", target);
}
void delete_chitatel()
{
    if (chitatel_count == 0)
    {
        printf("Массив пуст!\n");
        return;
    }

    char target[50];
    printf("Введите фамилию читателя для удаления: ");
    gets(target);   // без while(getchar...) и без getchar() после

    for (int i = 0; i < chitatel_count; i++)
    {
        if (strcmp(chitatels[i].fam, target) == 0)
        {
            for (int j = i; j < chitatel_count - 1; j++)
            {
                chitatels[j] = chitatels[j + 1];
            }
            chitatel_count--;
            printf("читатель с фамилией '%s' удалён.\n", target);
            return;
        }
    }

    printf("читатель с фамилией '%s' не найден.\n", target);
}
void save_to_file()
{
    if (chitatel_count == 0)
    {
        printf("Нет данных для сохранения в файл!\n");
        return;
    }

    FILE *vixod = fopen("vixod.txt", "w");
    if (vixod == NULL)
    {
        printf("Ошибка открытия файла!\n");
        return;
    }

    fprintf(vixod, "===== СПИСОК ЧИТАТЕЛЕЙ =====\n\n");

    for (int i = 0; i < chitatel_count; i++)
    {
        fprintf(vixod, "Читатель №%d\n", i + 1);
        fprintf(vixod, "Фамилия: %s\n", chitatels[i].fam);
        fprintf(vixod, "Имя: %s\n", chitatels[i].name);
        fprintf(vixod, "Отчество: %s\n", chitatels[i].otch);
        fprintf(vixod, "Книга: %s\n", chitatels[i].book_name);
        fprintf(vixod, "Срок сдачи: %s\n\n", chitatels[i].srok_sdachi);
    }

    fclose(vixod);

    printf("Данные успешно сохранены в файл vixod.txt\n");
}
